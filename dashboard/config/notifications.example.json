          "mentionedList": []
        },
        {
          "type": "telegram",
          "name": "telegram-ops",
          "botToken": "123456:YOUR_BOT_TOKEN",
          "chatId": "-1001234567890"
        },
        {
          "type": "dingtalk",
          "name": "dingtalk-ops",
          "webhook": "https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN",
          "secret": "SECxxxx",
          "atMobiles": [],
          "isAtAll": false
        }
      ]
    }
  ]
