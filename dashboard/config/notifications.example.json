{
  "enabled": false,
  "cooldownSec": 300,
  "remindIntervalSec": 0,
  "bindings": [
    {
      "name": "ops-all",
      "enabled": true,
      "targets": ["*"],
      "severities": ["offline", "danger"],
      "notifyRecover": true,
      "channels": [
        {
          "type": "wechat",
          "name": "wechat-ops",
          "webhook": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY",
