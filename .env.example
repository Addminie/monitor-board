# =========================
# Monitor Board env template
# Copy to .env and replace placeholders before deployment.
# =========================

# Agent auth (required in production)
AGENT_TOKEN=CHANGE_ME_STRONG_AGENT_TOKEN
METRICS_TOKEN=

# Dashboard RBAC (optional but recommended in production)
RBAC_TOKEN_READONLY=
RBAC_TOKEN_OPERATOR=
RBAC_TOKEN_ADMIN=

# Prometheus history backend for dashboard trends
PROMETHEUS_HISTORY_ENABLED=true
PROMETHEUS_BASE_URL=http://prometheus:9090
PROMETHEUS_QUERY_TIMEOUT_MS=10000
PROMETHEUS_TARGET_LABEL=target
API_PAGINATION_MAX=500

# Grafana admin credentials (for docker-compose.monitoring.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
